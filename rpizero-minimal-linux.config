# Raw Linux KCONFIG_ALLCONFIG miniconfig for Raspberry Pi Zero W (BCM2835, ARMv6).
# Goal: boot a static /init from a built-in initramfs.

CONFIG_EXPERT=y
CONFIG_KERNEL_GZIP=y

# Keep the userspace ABI needed by the static init binary.
CONFIG_MMU=y
CONFIG_AEABI=y
CONFIG_BINFMT_ELF=y
CONFIG_FUTEX=y

# ARMv6 single-core kernel for the BCM2835 in the Zero W.
CONFIG_ARCH_MULTIPLATFORM=y
CONFIG_ARCH_MULTI_V6=y
CONFIG_ARCH_BCM=y
CONFIG_ARCH_BCM2835=y

# Root filesystem supplied by initramfs in RAM.
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# UART console only.
CONFIG_TTY=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_8250_RUNTIME_UARTS=4
CONFIG_SERIAL_8250_EXTENDED=y
CONFIG_SERIAL_8250_SHARE_IRQ=y
CONFIG_SERIAL_8250_BCM2835AUX=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SERIAL_EARLYCON=y
CONFIG_PRINTK=y

# Device tree boot. The Zero W DTB is merged with required overlays and appended
# to zImage by the Nix build, while Raspberry Pi firmware supplies ATAGS.
CONFIG_OF=y
CONFIG_OF_FLATTREE=y
CONFIG_OF_EARLY_FLATTREE=y
CONFIG_ARM_APPENDED_DTB=y
CONFIG_ARM_ATAG_DTB_COMPAT=y
CONFIG_ARM_ATAG_DTB_COMPAT_CMDLINE_FROM_BOOTLOADER=y

# SD card exposed to the USB host by the mass-storage gadget.
CONFIG_BLOCK=y
CONFIG_MSDOS_PARTITION=y
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_BLOCK_MINORS=8
CONFIG_MMC_BCM2835=y

# USB OTG mass-storage gadget, configured by PID1 through configfs after the
# SD card block device appears.
CONFIG_USB_SUPPORT=y
CONFIG_NOP_USB_XCEIV=y
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_PERIPHERAL=y
CONFIG_USB_GADGET=y
CONFIG_USB_LIBCOMPOSITE=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_F_MASS_STORAGE=y

# The upstream Zero W DTB gives DWC2 a Raspberry Pi firmware power domain.
# Keep enough firmware/mailbox support for that domain to be explicitly powered.
CONFIG_PM=y
CONFIG_PM_GENERIC_DOMAINS=y
CONFIG_RESET_CONTROLLER=y
CONFIG_MAILBOX=y
CONFIG_BCM2835_MBOX=y
CONFIG_RASPBERRYPI_FIRMWARE=y
CONFIG_BCM2835_POWER=y
CONFIG_RASPBERRYPI_POWER=y

CONFIG_POSIX_TIMERS=y
CONFIG_COMPAT_32BIT_TIME=y
CONFIG_PROC_FS=y
CONFIG_DEVMEM=y
CONFIG_SYSFS=y
CONFIG_CLK_BCM2835=y

CONFIG_PANIC_ON_OOPS=y
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_CORE=y
CONFIG_BCM2835_WDT=y
